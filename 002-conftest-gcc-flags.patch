From: patched locally
Subject: [PATCH 2/5] Fix conftest build_cflags for GCC 12+

GCC 12+ treats implicit function declarations as errors by default.
Add flags to suppress these during conftest compilation.

--- a/kernel/conftest.sh
+++ b/kernel/conftest.sh
@@ -101,7 +101,8 @@
 build_cflags() {
     BASE_CFLAGS="-O2 -D__KERNEL__ \
 -DKBUILD_BASENAME=\"#conftest$$\" -DKBUILD_MODNAME=\"#conftest$$\" \
--nostdinc -isystem $ISYSTEM"
+-nostdinc -isystem $ISYSTEM \
+-Wno-implicit-function-declaration -Wno-strict-prototypes -Wno-incompatible-pointer-types"
 
     if [ "$OUTPUT" != "$SOURCES" ]; then
